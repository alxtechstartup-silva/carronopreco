{
  "entities": {
    "Vehicle": {
      "title": "Vehicle",
      "description": "A vehicle listing in the marketplace.",
      "type": "object",
      "properties": {
        "brand": { "type": "string" },
        "model": { "type": "string" },
        "year": { "type": "string" },
        "km": { "type": "string" },
        "price": { "type": "number" },
        "fipePrice": { "type": "number" },
        "description": { "type": "string" },
        "images": { "type": "array" },
        "category": { "type": "string" },
        "ownerId": { "type": "string" },
        "status": { "type": "string", "enum": ["active", "sold", "pending"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["brand", "model", "price", "ownerId"]
    },
    "Lead": {
      "title": "Lead",
      "description": "A customer interest lead for a vehicle.",
      "type": "object",
      "properties": {
        "customerName": { "type": "string" },
        "message": { "type": "string" },
        "vehicleInfo": { "type": "object" },
        "score": { "type": "number" },
        "priority": { "type": "string", "enum": ["high", "medium", "low"] },
        "advice": { "type": "string" },
        "assignedConsultant": { "type": "string" },
        "status": { "type": "string", "enum": ["new", "contacted", "closed"] },
        "createdAt": { "type": "string", "format": "date-time" },
        "userId": { "type": "string" }
      },
      "required": ["customerName", "vehicleInfo"]
    },
    "Analytic": {
      "title": "Analytic",
      "description": "A page view or event log.",
      "type": "object",
      "properties": {
        "event": { "type": "string" },
        "path": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" },
        "referrer": { "type": "string" },
        "userId": { "type": "string" }
      },
      "required": ["event", "path", "timestamp"]
    },
    "User": {
      "title": "User",
      "description": "A user profile.",
      "type": "object",
      "properties": {
        "email": { "type": "string" },
        "displayName": { "type": "string" },
        "role": { "type": "string", "enum": ["user", "admin", "dealer"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["email"]
    }
  },
  "firestore": {
    "/vehicles/{vehicleId}": {
      "schema": "Vehicle",
      "description": "Public vehicle listings."
    },
    "/leads/{leadId}": {
      "schema": "Lead",
      "description": "Confidential customer leads."
    },
    "/analytics/{analyticId}": {
      "schema": "Analytic",
      "description": "Internal business analytics."
    },
    "/users/{userId}": {
      "schema": "User",
      "description": "User profiles and permissions."
    }
  }
}
