# Variáveis de Ambiente para o Carro no Preço (Supabase & Gemini Integration)

# 1. API Key do Gemini Live (Utilizada no back-end para scoring, vistorias e atendimento)
GEMINI_API_KEY=

# 2. Configurações do Banco de Dados / Auth (Supabase)
# URL de conexão HTTP direta da API Rest do seu projeto
VITE_SUPABASE_URL=
# Chave pública anônima do cliente Supabase para requisições seguras via client-side
VITE_SUPABASE_ANON_KEY=

# 3. Configurações da Hospedagem (Hostinger Node.js)
# Porta na qual o servidor Express do Node.js iniciará (padrão é 3000)
PORT=3000
